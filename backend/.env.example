# Required for Router, Test generator, Design detector, AI detector, and Aggregator (OpenAI).
OPENAI_API_KEY=

# Optional overrides (defaults shown in README).
# OPENAI_MODEL=gpt-4o
# OPENAI_DESIGN_DETECTOR_MODEL=gpt-4o

# PMD: directory that contains the pmd executable (same layout as PMD zip bin/).
# PMD_BIN=/opt/pmd-bin-7.13.0/bin

# Checkstyle: path to rules XML (e.g. google_checks.xml).
# CHECKSTYLE_CONFIG=/path/to/google_checks.xml

# JPlag (optional; plagiarism node is not wired into the main graph by default).
# JPLAG_JAR=/path/to/jplag-jar-with-dependencies.jar
